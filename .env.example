# Cloudflare Worker URL for form submissions
# Get this from your Cloudflare Worker dashboard after creating the worker
VITE_FORM_WORKER_URL=https://form-handler.20jenselucjj.workers.dev/

# (Worker only) maximum number of submissions allowed per IP per hour.
# The worker will log a warning and return 429 when rate limit is reached.
RATE_LIMIT_PER_HOUR=100
